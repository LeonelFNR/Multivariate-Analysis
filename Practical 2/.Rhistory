#| include: false
library(GGally)
library(FactoMineR)
library(factoextra)
data = read.csv("https://raw.githubusercontent.com/Afrojam/toy_datasets/refs/heads/main/nyc.csv", row.names = 1)
head(data)
ggpairs(data)
data2 <- data[,1:4]
# pca on the data without scaling the variables. show principal components and their variance
res.pca.noscale <- PCA(data2, scale.unit = FALSE, graph = FALSE)
get_eigenvalue(res.pca.noscale)
fviz_eig(res.pca.noscale, addlabels = TRUE, choice = "variance", axes = 1 )
fviz_eig(res.pca.noscale, addlabels = TRUE, choice = "eigenvalue", axes = 1 )
# Comparing the variance of variables
diag(cov(data2))
res.pca <- PCA(data2, scale.unit = TRUE, graph = FALSE)
res.pca$eig
res.pca <- PCA(data2, scale.unit = TRUE, graph = FALSE)
#scree plot
fviz_eig(res.pca, addlabels = TRUE)
get_eigenvalue(res.pca)
res.pca$var$coord
res.pca$var$contrib
res.pca$var$cos2
fviz_contrib(res.pca, choice = "var", axes = 1)
fviz_contrib(res.pca, choice = "var", axes = 2)
# PCA scores (coordinates of individuals)
scores <- res.pca$ind$coord
# Contributions of individuals
contributions <- res.pca$ind$contrib
# Squared cosines of individuals
cosines <-res.pca$ind$cos2
scores["Rao's",]
contributions["Rao's",]
cosines["Rao's",]
scores["Gennaro",]
contributions["Gennaro",]
cosines["Gennaro",]
fviz_pca_var(res.pca,
col.var = "black",
repel = TRUE)
fviz_pca_ind(
res.pca,
select.ind = list(name = c("Veronica", "Rainbow Grill", "Lamarca")),
geom = c("point","text"),
repel = TRUE
)
#| eval: false
#| include: false
res <- PCA(data2)
restaurant <- c("Paola's","Sette Mezzo","Torre di Pisa","Primavera", "Veronica", "Rainbow Grill", "Fino", "Lamarca", "Basta Pasta")
subset <- res$ind$coord[restaurant,]
plot(subset, xlim = c(-5,5), ylim=c(-3,3), xlab = "PC1", ylab = "PC2")
text(subset, labels = rownames(subset), pos = 4, cex = 0.7)
abline(v=0, h=0)
plot(scale(data[restaurant,c(4,3)], scale = FALSE), xlab = "SERVICE", ylab = "DECOR")
text(scale(data[restaurant,c(4,3)], scale = FALSE), labels = rownames(subset), pos = 4, cex = 0.7)
abline(v=0, h=0)
res2 <- PCA(data, quali.sup="Location", graph=FALSE)
fviz_pca_ind(res2, select.ind = list(cos2=35),habillage = "Location", palette=c("#00AFBB", "#E7B800"), xlim=c(-4,4), ylim=c(-2,2), mean.point=FALSE, repel=TRUE)
library(psych)
data(attitude)
X <- attitude
n <- nrow(X)
p <- ncol(X)
Xs <- scale(X)
R <- 1/(n-1)*t(Xs)%*%Xs
res.eig <- eigen(R)
D <- diag(res.eig$values)
V <- res.eig$vectors
cumsum(res.eig$values)/sum(res.eig$values)
plot(1:7, res.eig$values, type = "b")
m <- 2
L_PCA <- V[,1:m] %*% sqrt(D[1:m,1:m])
L_PCA
h <- apply(L_PCA, 1, function(row) sum(row^2))
h
phi <- diag(diag(R-L_PCA %*% t(L_PCA)))
phi
L_varimax <- varimax(L_PCA)
L_varimax$loadings[1:p,1:m]
sigma <- L_PCA %*% t(L_PCA) + phi
scores <- Xs %*% solve(sigma) %*% L_PCA
scores
# ?fa
paste("Deegres of freedom of discrepancy function n*F_ML")
paste("m = ", 1:p, " df = ", 0.5*(p-1:p)^2-0.5*(p+1:p))
res1 <- fa(Xs, nfactors = 1, fm = "ml")
res2 <- fa(Xs, nfactors = 2, fm = "ml")
res3 <- fa(Xs, nfactors = 3, fm = "ml")
paste("p_value model m = 1: ", round(res1$PVAL,2))
paste("p_value model m = 2: ", round(res2$PVAL,2))
paste("p_value model m = 3: ", round(res3$PVAL,2))
L <- res2$loadings[1:p,1:2]
L
res2$communalities
res2$uniquenesses
h2 <- colSums(t(L)^2)
h2
res_varimax <- fa(Xs, nfactors = 2, fm = "ml", rotate = "varimax")
res_varimax$loadings[1:p,1:2]
res_oblimin <- fa(Xs, nfactors = 2, fm = "ml", rotate = "oblimin")
res_oblimin$loadings[1:p,1:2]
L_varimax <- res_varimax$loadings
L_oblimin <- res_oblimin$loadings
sigma_varimax <- L_varimax %*% t(L_varimax) + diag(res_varimax$uniquenesses)
sigma_oblimin <- L_oblimin %*% t(L_oblimin) + diag(res_oblimin$uniquenesses)
scores_varimax <- Xs %*% solve(sigma_varimax) %*% L_varimax
scores_oblimin <- Xs %*% solve(sigma_oblimin) %*% L_oblimin
scores_varimax
scores_oblimin
df_comparison <- cbind(varimax(L_PCA)$loadings[1:p,1:2],
L_varimax[1:p,1:2],
L_oblimin[1:p,1:2])
colnames(df_comparison) <- c("f1_PCA", "f2_PCA", "f1_MLV", "f2_MLV", "f1_MLO", "f2_MLO")
df_comparison
