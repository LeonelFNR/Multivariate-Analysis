# Dataset: Palmer Penguins
# Reason: It meets all criteria (344 rows, 3 categorical vars, 5 numeric vars)
# and allows for beautiful clustering visualizations.
url <- "https://raw.githubusercontent.com/allisonhorst/palmerpenguins/master/inst/extdata/penguins.csv"
data_penguins <- read.csv(url)
data_clean <- na.omit(data_penguins)
cat("Data loaded successfully. Rows:", nrow(data_clean), "\n")
cat("\n--- Generating Plot 1 (Parallel Coordinates) ---\n")
# We select columns 3 to 6 (numeric measurements) and col 1 (Species)
ggparcoord(data_clean,
columns = 3:6,
groupColumn = 1, # Group by Species
scale = "uniminmax", # Scale data to 0-1 for comparison
showPoints = TRUE,
title = "Plot 1: Parallel Coordinates - Species Differentiation",
alphaLines = 0.3) +
scale_color_manual(values=c( "#69b3a2", "#E8C245", "#FF9F55")) +
theme_minimal() +
theme(legend.position="bottom") +
xlab("") + ylab("Scaled Value")
