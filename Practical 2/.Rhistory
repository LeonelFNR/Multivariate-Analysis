#R Code to Generate the Datasets
# Set seed for reproducibility
set.seed(123)
N_music <- 5000
MusicStreaming <- data.frame(
UserID           = 1:N_music,
SongID           = sample(1:2000, N_music, replace = TRUE),
Genre            = sample(c("POP", "ROCK", "URB", "ELEC", "OTHER"),
N_music, replace = TRUE, prob = c(0.35, 0.25, 0.2, 0.15, 0.05)),
Platform         = sample(c("Spotify", "AppleMusic", "YouTubeMusic", "Other"),
N_music, replace = TRUE),
Streams          = rpois(N_music, lambda = 3000),
MinutesListened  = round(rgamma(N_music, shape = 5, rate = 0.2)),
Likes            = rpois(N_music, lambda = 50),
IsPremium        = sample(c(0, 1), N_music, replace = TRUE, prob = c(0.4, 0.6)),
Country          = sample(c("ES", "FR", "DE", "IT", "UK", "Other"),
N_music, replace = TRUE),
ListenDate       = sample(seq.Date(as.Date("2024-01-01"),
as.Date("2024-12-31"),
by = "day"),
N_music, replace = TRUE)
)
write.csv(MusicStreaming, "MusicStreaming.csv", row.names = FALSE)
