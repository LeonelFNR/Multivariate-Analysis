title: "Practical_Exercise 1"
library(stringr)
# Load necessary libraries
# [cite: 22, 24] - Using rvest for scraping as suggested
library(rvest)
library(dplyr)
library(stringr)
get_champions <- function(country, years_selected) {
# 1. Define URLs for at least 4 countries
# Using the specific Brazil URL provided by the user (co97)
urls <- list(
"Brazil"  = "https://www.worldfootball.net/competition/co97/records-winners-list/",
"Spain"   = "https://www.worldfootball.net/winner/esp-primera-division/",
"England" = "https://www.worldfootball.net/winner/eng-premier-league/",
"Italy"   = "https://www.worldfootball.net/competition/co111/italy-serie-a/records-winners-list/"
)
# 2. Error Handling: Check if country is supported [cite: 45]
if (!country %in% names(urls)) {
stop(paste("Error: Country not supported. Please choose one of:",
paste(names(urls), collapse = ", ")))
}
# 3. Web Scraping
url <- urls[[country]]
# Use tryCatch for robust connection handling
page <- tryCatch({
read_html(url)
}, error = function(e) {
stop("Error: Could not fetch the webpage. Check your internet connection.")
})
# Extract the first table (Winner list)
# [cite: 26] - Similar logic to the example provided in the PDF
raw_data <- html_table(page)[[1]]
# 4. Data Cleaning
# Standardize column names (Col 1 is usually Year, Col 3 is Team)
# We select by index to avoid language issues in headers
data <- raw_data[, c(1, 3)]
colnames(data) <- c("Year_Raw", "Team_Raw")
# Clean 'Year': Extract first 4 digits to handle "1999/2000" formats
data$Year <- as.numeric(str_extract(as.character(data$Year_Raw), "^[0-9]{4}"))
# Clean 'Team': Remove titles count in parenthesis, e.g., "Team (10.)"
data$Team <- str_trim(str_remove(data$Team_Raw, "\\(.*\\)"))
# 5. Filter by selected years
data_filtered <- data %>%
filter(Year %in% years_selected)
# Check if data exists for the selection
if (nrow(data_filtered) == 0) {
warning("No records found for the specified years.")
return(NULL)
}
# 6. Create Frequency Table
freq_table <- data_filtered %>%
group_by(Team) %>%
summarise(Freq = n()) %>%
mutate(Percent_Num = (Freq / sum(Freq)) * 100,
Percent = paste0(format(round(Percent_Num, 2), nsmall = 2), " %")) %>%
arrange(desc(Freq)) %>%
select(Team, Freq, Percent)
# Add Total Row [cite: 44] - Matching the example format in PDF
total_row <- data.frame(
Team = "Total",
Freq = sum(freq_table$Freq),
Percent = "100.00 %"
)
final_table <- rbind(freq_table, total_row)
# Print descriptive message [cite: 42]
cat(paste("Champions (Football) in", country, "for the selected years.\n"))
return(final_table)
}
# Example 1: Brazil (using the requested URL data)
# Selecting a mix of years to test the filter
cat("\n--- Example 1: Brazil ---\n")
years_br <- c(2023, 2022, 2021, 2020, 2019, 2010, 2005)
print(get_champions("Brazil", years_br))
# Example 2: Spain (Different country)
cat("\n--- Example 2: Spain ---\n")
years_es <- c(2024, 2023, 2022, 2000, 1999)
print(get_champions("Spain", years_es))
# Example 3: Error Handling (Invalid Country) [cite: 45]
cat("\n--- Example 3: Error Handling ---\n")
try({
get_champions("Germany", c(2020)) # Germany is not in our list
})
# =============================================================================
# Load necessary libraries
library(ggplot2)
library(corrplot)
library(lattice)
library(dplyr)
# Import code:
url <- "https://raw.githubusercontent.com/allisonhorst/palmerpenguins/master/inst/extdata/penguins.csv"
data_penguins <- read.csv(url)
# Data Cleaning: Remove rows with NA values for cleaner plotting
data_clean <- na.omit(data_penguins)
# Verify the structure satisfies requirements
str(data_clean)
cat("\nNumber of records:", nrow(data_clean), "\n") # Check > 50
cat("\n--- Generating Plot 1 (ggplot2) ---\n")
plot1 <- ggplot(data_clean, aes(x = flipper_length_mm, y = body_mass_g)) +
geom_point(aes(color = species, size = bill_depth_mm), alpha = 0.7) +
scale_color_manual(values = c("darkorange", "purple", "cyan4")) +
theme_minimal() +
labs(
title = "Plot 1: Penguin Size Characteristics by Species",
subtitle = "Flipper Length vs Body Mass (Size = Bill Depth)",
x = "Flipper Length (mm)",
y = "Body Mass (g)",
color = "Species",
size = "Bill Depth"
)
print(plot1)
cat("\n--- Generating Plot 2 (corrplot) ---\n")
# Select only numeric columns for correlation
numeric_vars <- data_clean %>%
select(bill_length_mm, bill_depth_mm, flipper_length_mm, body_mass_g, year)
# Calculate correlation matrix
M <- cor(numeric_vars)
# Generate Plot
corrplot(M, method = "ellipse", type = "upper",
tl.col = "black", tl.srt = 45,
title = "\nPlot 2: Correlation Matrix of Numeric Variables",
addCoef.col = "black") # Add numeric coefficient
cat("\n--- Generating Plot 3 (lattice) ---\n")
# Density plot of Bill Length conditioned by Island
plot3 <- densityplot(~ bill_length_mm | island, data = data_clean,
plot.points = FALSE,
col = "darkgreen",
lwd = 2,
main = "Plot 3: Distribution of Bill Length by Island",
xlab = "Bill Length (mm)")
print(plot3)
